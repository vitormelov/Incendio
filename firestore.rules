rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'projetos@preferencial.eng.br';
    }

    function isCollaborador() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return signedIn()
        && exists(path)
        && get(path).data.get('permissions', []) is list
        && 'colaborador' in get(path).data.get('permissions', []);
    }

    // Usuários
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Incêndios
    match /incendios/{incendioId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    // Clientes (módulo Administrativo)
    match /clientesAdministrativos/{clienteId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    // Serviços por obra (pacote/descrição/verba)
    match /obraServices/{serviceId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Notas por obra (vinculadas opcionalmente a um serviço)
    match /obraNotes/{noteId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // RDO (Relatório Diário de Obra)
    match /obraRdos/{rdoId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    // Medições (cliente×obra e obra×prestadores) — edição só para admin e colaboradores
    match /obraMedicoes/{obraId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isCollaborador();
    }

    // Informações da obra
    match /obraInformacoes/{obraId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isCollaborador();
    }
  }
}

