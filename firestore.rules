rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'projetos@preferencial.eng.br';
    }

    // Usuários
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Incêndios
    match /incendios/{incendioId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    // Serviços por obra (pacote/descrição/verba)
    match /obraServices/{serviceId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Notas por obra (vinculadas opcionalmente a um serviço)
    match /obraNotes/{noteId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}

